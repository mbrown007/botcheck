{
  "name": "botcheck-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:cycles": "madge --circular src --extensions ts,tsx --ts-config tsconfig.json",
    "test:unit": "tsx --test 'src/__tests__/**/*.test.ts' 'src/__tests__/**/*.test.tsx'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "gen:openapi-schema": "uv run --project ../services/api python ../services/api/scripts/export_openapi.py --out src/lib/api/openapi.json",
    "gen:api-types": "npm run gen:openapi-schema && openapi-typescript src/lib/api/openapi.json -o src/lib/api/generated.ts",
    "gen:api-types:check": "npm run gen:api-types && git diff --exit-code -- src/lib/api/openapi.json src/lib/api/generated.ts"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/dagre": "^0.7.54",
    "@uiw/react-codemirror": "^4.21.0",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.12.0",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.3.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "madge": "^8.0.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
