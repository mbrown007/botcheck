# ── Copy to .env and fill in values ──────────────────────────────────────────
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=botcheck_dev

# ── Redis ────────────────────────────────────────────────────────────────────
# (no password in dev; set REDIS_URL with auth in prod)

# ── Object Storage (MinIO in dev / S3 in prod) ───────────────────────────────
MINIO_ROOT_USER=botcheck
MINIO_ROOT_PASSWORD=botcheck_dev_secret

# ── LiveKit ──────────────────────────────────────────────────────────────────
# Dev: livekit-server --dev uses these fixed values
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret00000000000000000000000

# ── BotCheck API ─────────────────────────────────────────────────────────────
SECRET_KEY=dev_secret_key_change_in_production
SCHEDULER_SECRET=dev-scheduler-secret
# Phase 6 local auth bootstrap (interim before OIDC)
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=admin@botcheck.local
# Use LOCAL_AUTH_PASSWORD_HASH in production (KDF hash) and leave plaintext blank.
LOCAL_AUTH_PASSWORD=botcheck-dev-password
LOCAL_AUTH_PASSWORD_HASH=
LOCAL_AUTH_TOKEN_TTL_S=900
LOCAL_AUTH_REFRESH_TOKEN_TTL_S=28800
LOCAL_AUTH_RATE_LIMIT_ATTEMPTS=10
LOCAL_AUTH_RATE_LIMIT_WINDOW_S=60
LOCAL_AUTH_LOCKOUT_FAILED_ATTEMPTS=5
LOCAL_AUTH_LOCKOUT_DURATION_S=900
AUTH_TOTP_CHALLENGE_TTL_S=300
AUTH_TOTP_STEP_S=30
AUTH_TOTP_WINDOW=1
AUTH_TOTP_REPLAY_TTL_S=120
AUTH_SECURITY_REDIS_ENABLED=true
AUTH_SECURITY_REDIS_PREFIX=botcheck:authsec
AUTH_SECURITY_REDIS_TIMEOUT_S=0.2
AUTH_SECURITY_REDIS_FAILURE_BACKOFF_S=5
# Fernet key (URL-safe base64, 32-byte raw key). Required in production.
AUTH_TOTP_ENCRYPTION_KEY=
USERS_BOOTSTRAP_ENABLED=true
USERS_BOOTSTRAP_PATH=services/api/botcheck_api/users.yaml
# Web-only dev token for tenant bootstrap lookup on login page.
# Leave empty in production.
NEXT_PUBLIC_DEV_USER_TOKEN=
# Canonical timezone for this deployment/instance (used as schedule default)
INSTANCE_TIMEZONE=UTC
# Default transcript/artifact retention profile for new runs.
# one of: ephemeral|standard|compliance|no_audio
DEFAULT_RETENTION_PROFILE=standard
# Tenant context policy (Phase 6 item 84)
SHARED_INSTANCE_MODE=false
TENANT_SWITCHER_ALLOWED_ROLES=admin

# ── External AI APIs ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# ── Bot Under Test (used in scenario YAML via ${VAR}) ───────────────────────
BOT_SIP_URI=sip:bot@your-sip-provider.com
BOT_SIP_USER=bot
SIP_PROVIDER=your-sip-provider.com

# ── Outbound SIP Dispatch (API -> LiveKit SIP) ──────────────────────────────
# Enable for real trunk dialing; leave false for mock-bot dev flow.
ENABLE_OUTBOUND_SIP=false
SIP_SECRET_PROVIDER=env
# Secret provider policy:
# - local/dev: use `env`
# - staging/prod: use `aws_secrets_manager` or `vault`
ALLOW_ENV_SIP_SECRETS_IN_PRODUCTION=false
SIP_SECRET_CACHE_TTL_S=60
SIP_TRUNK_ID=
SIP_AUTH_USERNAME=
SIP_AUTH_PASSWORD=
SIP_SECRET_REF=
SIP_SECRET_REGION=us-east-1
SIP_SECRET_TIMEOUT_S=5
# Vault provider settings (required when SIP_SECRET_PROVIDER=vault)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_KV_VERSION=2
# Comma-separated domain allowlist, e.g. "sipgate.com,eu.sipgate.com"
SIP_DESTINATION_ALLOWLIST=
# Capacity controls for outbound SIP dispatch (item 14)
MAX_CONCURRENT_OUTBOUND_CALLS=5
SIP_DISPATCH_SLOT_TTL_S=900
SCHEDULE_DISPATCH_BACKOFF_S=15
SCHEDULE_DISPATCH_BACKOFF_JITTER_S=5
SCHEDULE_DISPATCH_MAX_ATTEMPTS=5

# ── Metrics / Observability ──────────────────────────────────────────────────
# Local/dev default: Prometheus is the authoritative metrics stack; Alloy stays
# up for traces only. Set to `alloy` when you want Alloy to scrape/push metrics.
METRICS_STACK=prometheus
# Structured logs (Loki/Grafana friendly JSON)
LOG_LEVEL=INFO
LOG_JSON=true
# API metrics are exposed on /metrics at port 7700.
JUDGE_METRICS_ENABLED=true
JUDGE_METRICS_PORT=9101
# Judge retention sweeper (Phase 2)
RETENTION_SWEEP_ENABLED=true
RETENTION_SWEEP_DRY_RUN=false
RETENTION_SWEEP_LIMIT=500
SCHEDULE_TICK_ENABLED=true
SCHEDULE_TICK_LIMIT=50
AGENT_METRICS_ENABLED=true
AGENT_METRICS_PORT=9102
# Harness final-ACK recovery queue/log (item 34)
FINAL_ACK_RECOVERY_ENABLED=true
FINAL_ACK_RECOVERY_LOG_PATH=/tmp/botcheck-agent-final-ack-recovery.jsonl
# Harness read-through TTS cache (Phase 7)
# Keep this value aligned across API, agent, and cache-worker containers.
TTS_CACHE_ENABLED=true
TTS_CACHE_PCM_FORMAT_VERSION=v1
TTS_PREVIEW_RATE_LIMIT_ATTEMPTS=30
TTS_PREVIEW_RATE_LIMIT_WINDOW_S=60
TTS_PREVIEW_OPENAI_MODEL=gpt-4o-mini-tts
TTS_PREVIEW_REQUEST_TIMEOUT_S=20
S3_BUCKET_PREFIX=botcheck-artifacts

# Judge adversarial multi-sample mode (item 22)
MULTI_SAMPLE_JUDGE=false
MULTI_SAMPLE_JUDGE_N=3

# Phase 10: AI Scenario Generator (Wizard)
SCENARIO_GENERATOR_RATE_LIMIT_PER_HOUR=10
SCENARIO_GENERATOR_MODEL=claude-sonnet-4-5-20251001

# ── Grafana Cloud Monitoring ────────────────────────────────────────────────
# Found in your Grafana Cloud portal (Prometheus section)
GRAFANA_CLOUD_URL=https://prometheus-prod-01-eu-west-0.grafana.net/api/prom/push
GRAFANA_CLOUD_USER=your-user-id
GRAFANA_CLOUD_TOKEN=your-api-token

# ── Grafana Cloud Traces (Tempo) ────────────────────────────────────────────
# Found in your Grafana Cloud portal (Tempo -> Sending data)
# Endpoint should be host:port (no scheme), e.g. tempo-prod-25-prod-gb-south-1.grafana.net:443
GRAFANA_CLOUD_TEMPO_ENDPOINT=tempo-prod-25-prod-gb-south-1.grafana.net:443
GRAFANA_CLOUD_TEMPO_USER=1493095
GRAFANA_CLOUD_TEMPO_TOKEN=your-api-token

# OTLP settings used by LiveKit/SIP exporters in docker-compose
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be changed from the default in any non-local deployment.
METRICS_SCRAPE_TOKEN=botcheck-dev-metrics-token
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
LIVEKIT_OTEL_SERVICE_NAME=livekit-server
SIP_OTEL_SERVICE_NAME=livekit-sip

# ── SSL & Proxy (Caddy) ─────────────────────────────────────────────────────
ACME_EMAIL=your-email@example.com
API_DOMAIN=api.botchecker.dev
LIVEKIT_DOMAIN=livekit.botchecker.dev

# ── Release Audio Gate (CI/manual workflow) ─────────────────────────────────
# Optional defaults used by scripts/ci/audio_release_gate.sh
BOTCHECK_API_URL=http://localhost:7700
BOTCHECK_GATE_TIMEOUT_S=900
BOTCHECK_GATE_POLL_S=5
